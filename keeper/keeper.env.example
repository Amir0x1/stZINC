# Copy to keeper.env and fill in. keeper.env is gitignored — never commit it.

# Mainnet RPC endpoint (Helius/QuickNode/Triton recommended over the public RPC).
RPC_URL=https://your-mainnet-rpc

# The vault MANAGER key — signs deposit_strategy AND pays the (tiny) tx fee.
# Option A: path to the keypair JSON file on this box (chmod 600).
MANAGER_KEYPAIR=/opt/stzinc-keeper/manager.json
# Option B (instead of a file): inline secret key as a JSON byte array.
# MANAGER_SECRET_KEY=[12,34,...]

# Optional priority fee per compute unit (micro-lamports). Default 20000.
# PRIORITY_MICROLAMPORTS=20000

# Fee harvesting. After each crank the keeper mints accrued vault fees out to the
# admin/manager/protocol stZINC ATAs, but only once the total accrued reaches the
# floor below (avoids spending a tx on dust every run). Harvest failures are
# logged and never fail the run.
# HARVEST=1                   # set to 0/false to disable harvesting entirely
# HARVEST_MIN_STZINC=0.01     # minimum accrued (stZINC) before a harvest tx is sent
